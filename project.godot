; Godot 4 프로젝트 설정 — 나라카찌
; 도트 규격은 docs/adr/0001-dot-art-spec.md 참조 (270×480 / Nearest / 정수배)

config_version=5

[application]

config/name="나라카찌"
config/description="나라카 컨셉카페 팬게임 — 도트 데일리 교감·수집 게임"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[display]

; 베이스 캔버스 270×480 (9:16 세로), 정수배 스케일 + 레터박스
window/size/viewport_width=270
window/size/viewport_height=480
window/size/window_width_override=540
window/size/window_height_override=960
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/stretch/scale_mode="integer"
; 모바일 세로 고정
window/handheld/orientation=1

[rendering]

; 웹 호환성 우선
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
; 도트 또렷하게 — 전역 Nearest 필터
textures/canvas_textures/default_texture_filter=0
